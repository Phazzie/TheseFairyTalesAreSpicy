# ============================================================
# REQUIRED — App will not function without these
# ============================================================

# xAI Grok API key — get from https://console.x.ai
XAI_API_KEY=your_xai_api_key_here

# ElevenLabs API key — get from https://elevenlabs.io (v1.1+ feature)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Supabase project URL — from your Supabase project dashboard
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous key — safe to expose in client, limited permissions
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key — NEVER expose in client. Server-side only.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Allowed frontend origin for CORS (e.g. https://your-app.vercel.app or http://localhost:8081)
FRONTEND_URL=http://localhost:8081

# ============================================================
# OPTIONAL — Required when Pro subscription tier launches
# ============================================================

# Stripe secret key — for Pro subscription billing
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Stripe webhook signing secret — for verifying webhook events
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ============================================================
# EXPO PUBLIC VARS — safe to expose in the app bundle
# ============================================================

# Your Supabase project URL (same as SUPABASE_URL, EXPO_PUBLIC_ prefix for client)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon key (same as SUPABASE_ANON_KEY, EXPO_PUBLIC_ prefix for client)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your deployed API base URL (e.g. https://your-app.vercel.app or http://localhost:3000 for dev)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Stripe Checkout page URL for Pro upgrade (shown in UpgradeSheet)
EXPO_PUBLIC_UPGRADE_URL=https://your-stripe-checkout-link-here
